<nav class="navbar">
    <div class="nav-container">
        <a href="/" class="nav-brand"> WatchList  </a>

        <div class="nav-right-group">
            <% if (user) { %>
                <span class="user-greeting">Hello, <%= user %>!</span>
            <% } %>

            <div class="nav-links">
                <a href="/" class="nav-link <%= currentPage === 'home' ? 'active' : '' %>">Home</a>
                <a href="/search" class="nav-link <%= currentPage === 'search' ? 'active' : '' %>"> Search</a>
                <a href="/watchlist" class="nav-link <%= currentPage === 'watchlist' ? 'active' : '' %>"> My Watchlist</a>
                <% if (user && user !== "Guest") { %>
                    <a href="/logout" class="nav-link">Logout</a>
                <% } else { %>
                    <a href="/login" class="nav-link">Login</a>
                <% } %>
            </div>
        </div>
    </div>
</nav>