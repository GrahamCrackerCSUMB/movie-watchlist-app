<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Results - WatchList</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/nav.ejs') %>

<main class="content-wrapper">
    <header class="results-header">
        <h1>Search Results</h1>
        <a href="/search" class="btn-link">← New Search</a>
    </header>

    <div class="results-container">
        <% if (movies.length === 0) { %>
            <p>No movies found. Try a different title!</p>
        <% } else { %>
            <% movies.forEach(movie => { %>
                <div class="movie-result-card">
                    <div class="card-image">
                        <% if (movie.poster_path) { %>
                            <img src="https://image.tmdb.org/t/p/w200<%= movie.poster_path %>" alt="<%= movie.title %>">
                        <% } else { %>
                            <div class="no-poster">No Image</div>
                        <% } %>
                    </div>

                    <div class="card-content">
                    <h3>
                        <% if (user) { %>
                            <form action="/watchlist/add" method="POST" class="title-add-form">
                                <input type="hidden" name="tmdb_id" value="<%= movie.id %>">
                                <input type="hidden" name="title" value="<%= movie.title %>">
                                <input type="hidden" name="poster_path" value="<%= movie.poster_path %>">
                                <input type="hidden" name="genre_id" value="<%= movie.genre_ids[0] %>">
                                <input type="hidden" name="redirectTo" value="/edit/<%= movie.id %>">

                                <button type="submit" class="movie-title-link title-button">
                                    <%= movie.title %> (<%= movie.release_date ? movie.release_date.split('-')[0] : 'N/A' %>)
                                </button>
                            </form>
                        <% } else { %>
                            <a href="/guest-movie/<%= movie.id %>"
                            class="movie-title-link"
                            onclick="saveGuestMovieBeforeLink(event, {
                                tmdb_id: '<%= movie.id %>',
                                title: '<%= movie.title %>',
                                poster_url: 'https://image.tmdb.org/t/p/w500<%= movie.poster_path %>',
                                genre: '<%= movie.genre_name %>',
                                rating: 0,
                                watched_status: 0,
                                personal_review: ''
                            }, this.href)">
                                <%= movie.title %> (<%= movie.release_date ? movie.release_date.split('-')[0] : 'N/A' %>)
                            </a>
                        <% } %>
                    </h3>

                        <div class="movie-stats">
                            <p><strong>Genre:</strong> <%= movie.genre_name %></p>
                            <p><strong>TMDb Rating:</strong> <%= Number(movie.rating_score).toFixed(1) %>/10</p>
                        </div>

                        <div class="card-actions">
                            <button type="button" class="btn-reviews" onclick="loadMovieReviews(<%= movie.id %>, this)">
                                Community Reviews
                            </button>

                            <% if (user) { %>
                                <form action="/watchlist/add" method="POST" class="add-watchlist-form">
                                    <input type="hidden" name="tmdb_id" value="<%= movie.id %>">
                                    <input type="hidden" name="title" value="<%= movie.title %>">
                                    <input type="hidden" name="poster_path" value="<%= movie.poster_path %>">
                                    <input type="hidden" name="genre_id" value="<%= movie.genre_ids[0] %>">
                                    <% if (movie.inWatchlist) { %>
                                        <button type="button" class="btn-add" disabled style="background-color:#444;">
                                            Already in Watchlist
                                        </button>
                                    <% } else { %>
                                        <button type="submit" class="btn-add">Add to Watchlist</button>
                                    <% } %>
                                </form>
                            <% } else { %>
                                <button type="button" 
                                    class="btn-add guest-btn"
                                    data-tmdb-id="<%= movie.id %>"
                                        onclick="saveToGuestWatchlist({
                                            tmdb_id: '<%= movie.id %>',
                                            title: '<%= movie.title %>',
                                            poster_url: 'https://image.tmdb.org/t/p/w500<%= movie.poster_path %>',
                                            genre: '<%= movie.genre_name %>',
                                            rating: 0,
                                            watched_status: 0,
                                            personal_review: ''
                                        }, this)">
                                    Add to Watchlist
                                </button>
                            <% } %>
                        </div>

                        <div id="reviews-<%= movie.id %>" class="reviews-dropdown"></div>
                    </div>
                </div>
            <% }); %>
        <% } %>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function () {
    const watchlist = JSON.parse(localStorage.getItem('watchlist') || '[]');

    document.querySelectorAll('.guest-btn').forEach(button => {
        const tmdbId = button.dataset.tmdbId;

        const alreadySaved = watchlist.some(movie => String(movie.tmdb_id) === String(tmdbId));

        if (alreadySaved) {
            button.textContent = "Already in Watchlist";
            button.style.backgroundColor = "#444";
            button.disabled = true;
        }
    });
});

    function saveGuestMovieBeforeLink(event, movie, url) {
    event.preventDefault();

    let watchlist = JSON.parse(localStorage.getItem('watchlist') || '[]');

    const alreadySaved = watchlist.some(m => String(m.tmdb_id) === String(movie.tmdb_id));

    if (!alreadySaved) {
        watchlist.push(movie);
        localStorage.setItem('watchlist', JSON.stringify(watchlist));
    }

    window.location.href = url;
}

    function saveToGuestWatchlist(movie, button) {
        let watchlist = JSON.parse(localStorage.getItem('watchlist') || '[]');

        if (watchlist.some(m => String(m.tmdb_id) === String(movie.tmdb_id))) {
            button.textContent = "Already in Watchlist";
            button.style.backgroundColor = "#444";
            button.disabled = true;  
            return;
}

        watchlist.push(movie);
        localStorage.setItem('watchlist', JSON.stringify(watchlist));

        button.style.backgroundColor = "#28a745";
        button.textContent = "Saved to Browser!";
        button.disabled = true;
    }

    async function loadMovieReviews(movieId, button) {
        const reviewBox = document.getElementById(`reviews-${movieId}`);
        const cacheKey = `reviews-${movieId}`;

        if (reviewBox.innerHTML !== "") {
            reviewBox.innerHTML = "";
            button.textContent = "Community Reviews";
            return;
        }

        const saved = localStorage.getItem(cacheKey);
        if (saved) {
            reviewBox.innerHTML = saved;
            button.textContent = "Hide Reviews";
            return;
        }

        button.textContent = "Loading...";

        try {
            const response = await fetch(`/api/fake-reviews/${movieId}`);
            const data = await response.json();

            let html = `
                <div class="review-box-inner">
                    <p class="likes-count">WatchList Engagement: ${data.totalLikes} likes</p>
            `;

            data.reviews.forEach(review => {
                html += `
                    <div class="mini-review">
                        <strong>${review.reviewer}</strong>
                        <p>${review.text}</p>
                    </div>
                `;
            });

            html += `</div>`;
            reviewBox.innerHTML = html;
            localStorage.setItem(cacheKey, html);
            button.textContent = "Hide Reviews";

        } catch (err) {
            reviewBox.innerHTML = "<p class='error'>Error loading reviews.</p>";
            button.textContent = "Community Reviews";
        }
    }
</script>

<%- include('partials/footer.ejs') %>
</body>
</html>